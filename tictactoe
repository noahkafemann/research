<script>
/* ============================================================
   1) SCROLL PROGRESS + MODULE REVEAL ON SCROLL
   ============================================================ */
const progressBar = document.getElementById('progress-bar');
function updateProgress(){
  const h = document.documentElement;
  const scrolled = h.scrollTop;
  const max = h.scrollHeight - h.clientHeight;
  progressBar.style.width = (max > 0 ? (scrolled / max) * 100 : 0) + '%';
}
document.addEventListener('scroll', updateProgress);
updateProgress();

const modules = document.querySelectorAll('[data-module]');
const navStatus = document.getElementById('nav-status');
const moduleNames = {
  m1:'SPIELFELD', m2:'ANZEIGE', m3:'EINGABE', m4:'SPIELERWECHSEL',
  m5:'GEWINNPRÜFUNG', m6:'UNENTSCHIEDEN', m7:'HAUPTSCHLEIFE', m8:'KI / MINIMAX', m9:'LIVE-DEMO'
};
const io = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if(entry.isIntersecting){
      entry.target.classList.add('in-view');
      if(moduleNames[entry.target.id]){
        navStatus.textContent = moduleNames[entry.target.id];
      }
    }
  });
}, { threshold: 0.18 });
modules.forEach(m => io.observe(m));

/* ============================================================
   2) CODE REVEAL BUTTONS
   ============================================================ */
document.querySelectorAll('[data-reveal]').forEach(btn => {
  btn.addEventListener('click', () => {
    const key = btn.getAttribute('data-reveal');
    const wrap = document.querySelector(`[data-wrap="${key}"]`);
    const veil = document.querySelector(`[data-veil="${key}"]`);
    const explain = document.querySelector(`[data-explain="${key}"]`);
    const isOpen = wrap.classList.contains('open');
    if(!isOpen){
      wrap.classList.add('open');
      veil.classList.add('hidden-veil');
      btn.textContent = 'Erklärung anzeigen';
      btn.classList.add('revealed');
      btn.dataset.stage = 'code';
    } else if(btn.dataset.stage === 'code'){
      explain.classList.add('show');
      btn.textContent = 'Code & Erklärung ausblenden';
      btn.dataset.stage = 'explained';
      const moduleEl = btn.closest('[data-module]');
      const marker = moduleEl ? moduleEl.querySelector('[data-marker]') : null;
      if(marker){ marker.textContent = '● gelesen'; marker.classList.add('complete'); }
    } else {
      wrap.classList.remove('open');
      veil.classList.remove('hidden-veil');
      explain.classList.remove('show');
      btn.textContent = 'Code aufdecken';
      btn.classList.remove('revealed');
      btn.dataset.stage = '';
    }
  });
  // Veil itself is also clickable
  const key = btn.getAttribute('data-reveal');
  const veil = document.querySelector(`[data-veil="${key}"]`);
  if(veil){ veil.addEventListener('click', () => btn.click()); }
});

/* ============================================================
   3) SELF-CHECK QUIZZES
   ============================================================ */
document.querySelectorAll('[data-quiz]').forEach(quiz => {
  const opts = quiz.querySelectorAll('.quiz-opt');
  const fb = quiz.querySelector('[data-fb]');
  opts.forEach(opt => {
    opt.addEventListener('click', () => {
      if(quiz.dataset.answered) return;
      quiz.dataset.answered = 'true';
      const correct = opt.getAttribute('data-correct') === 'true';
      opts.forEach(o => {
        if(o.getAttribute('data-correct') === 'true'){ o.classList.add('correct'); }
        else if(o === opt){ o.classList.add('wrong'); }
      });
      fb.textContent = correct
        ? 'Richtig. Weiter geht\'s.'
        : 'Nicht ganz — die korrekte Antwort ist grün markiert.';
      fb.classList.add('show');
    });
  });
});

/* ============================================================
   4) PLAYABLE TICTACTOE — JS PORT OF THE PYTHON LOGIC + MINIMAX AI
   ============================================================ */
(function(){
  const EMPTY = " ";
  let field = Array(9).fill(EMPTY);
  let humanMark = "X";
  let aiMark = "O";
  let current = "X";
  let gameOver = false;

  const boardEl = document.getElementById('board');
  const statusEl = document.getElementById('status');
  const consoleEl = document.getElementById('console');
  const btnRestart = document.getElementById('btn-restart');
  const btnFirst = document.getElementById('btn-first');

  const WIN_LINES = [
    [0,1,2],[3,4,5],[6,7,8],
    [0,3,6],[1,4,7],[2,5,8],
    [0,4,8],[2,4,6]
  ];

  function logLine(text, cls){
    const div = document.createElement('div');
    div.className = 'line' + (cls ? ' ' + cls : '');
    div.textContent = text;
    consoleEl.appendChild(div);
    consoleEl.scrollTop = consoleEl.scrollHeight;
  }

  function nextPlayer(p){ return p === "X" ? "O" : "X"; }

  // direct port of check_win(player)
  function checkWin(player){
    for(const [a,b,c] of WIN_LINES){
      if(field[a] === field[b] && field[b] === field[c] && field[c] === player){
        return [a,b,c];
      }
    }
    return null;
  }
  function isWin(player){ return checkWin(player) !== null; }

  // direct port of check_unentschieden()
  function checkDraw(){ return !field.includes(EMPTY); }

  function freeFields(){
    const out = [];
    for(let i=0;i<9;i++){ if(field[i] === EMPTY) out.push(i); }
    return out;
  }

  // direct port of the minimax() from Modul 8
  function minimax(spielerAmZug, kiZeichen){
    const mensch = nextPlayer(kiZeichen);
    if(isWin(kiZeichen)) return { wert: 1, zug: null };
    if(isWin(mensch)) return { wert: -1, zug: null };
    if(checkDraw()) return { wert: 0, zug: null };

    let besterZug = null;
    let besterWert = (spielerAmZug === kiZeichen) ? -Infinity : Infinity;

    for(const zug of freeFields()){
      field[zug] = spielerAmZug;
      const { wert } = minimax(nextPlayer(spielerAmZug), kiZeichen);
      field[zug] = EMPTY;

      if(spielerAmZug === kiZeichen && wert > besterWert){
        besterWert = wert; besterZug = zug;
      }
      if(spielerAmZug !== kiZeichen && wert < besterWert){
        besterWert = wert; besterZug = zug;
      }
    }
    return { wert: besterWert, zug: besterZug };
  }

  function kiMove(){
    const { zug } = minimax(aiMark, aiMark);
    if(zug === null || zug === undefined) return;
    field[zug] = aiMark;
    logLine(`KI (${aiMark}) wählt Feld ${zug + 1}`, 'o');
  }

  function renderBoard(){
    boardEl.innerHTML = '';
    field.forEach((val, i) => {
      const cell = document.createElement('div');
      cell.className = 'cell' + (val !== EMPTY ? ' taken' : '');
      cell.setAttribute('role','gridcell');
      cell.setAttribute('aria-label', `Feld ${i+1}${val !== EMPTY ? ', belegt mit ' + val : ', frei'}`);
      if(val === 'X') cell.innerHTML = '<span class="mark-x">X</span>';
      if(val === 'O') cell.innerHTML = '<span class="mark-o">O</span>';
      cell.addEventListener('click', () => onCellClick(i));
      boardEl.appendChild(cell);
    });
  }

  function highlightWin(line){
    if(!line) return;
    line.forEach(i => {
      const cellEl = boardEl.children[i];
      if(cellEl) cellEl.classList.add('win');
    });
  }

  function onCellClick(i){
    if(gameOver || current !== humanMark) return;
    if(field[i] !== EMPTY){
      logLine(`Fehler: Feld ${i+1} ist schon belegt!`, 'sys');
      return;
    }
    field[i] = humanMark;
    logLine(`Spieler ${humanMark} wählt Feld ${i + 1}`, 'x');
    renderBoard();
    afterMove();
  }

  function afterMove(){
    const winLine = checkWin(current);
    if(winLine){
      gameOver = true;
      renderBoard();
      highlightWin(winLine);
      statusEl.textContent = `Spieler ${current} hat gewonnen!`;
      logLine(`Spieler ${current} hat gewonnen!`, 'win');
      return;
    }
    if(checkDraw()){
      gameOver = true;
      statusEl.textContent = 'Unentschieden!';
      logLine('Unentschieden!', 'win');
      return;
    }
    current = nextPlayer(current);
    statusEl.textContent = current === humanMark ? 'Du bist am Zug.' : 'KI denkt nach …';

    if(current === aiMark && !gameOver){
      setTimeout(() => {
        kiMove();
        renderBoard();
        const aiWinLine = checkWin(aiMark);
        if(aiWinLine){
          gameOver = true;
          highlightWin(aiWinLine);
          statusEl.textContent = `KI (${aiMark}) hat gewonnen!`;
          logLine(`KI (${aiMark}) hat gewonnen!`, 'win');
          return;
        }
        if(checkDraw()){
          gameOver = true;
          statusEl.textContent = 'Unentschieden!';
          logLine('Unentschieden!', 'win');
          return;
        }
        current = nextPlayer(current);
        statusEl.textContent = 'Du bist am Zug.';
      }, 380);
    }
  }

  function restart(){
    field = Array(9).fill(EMPTY);
    current = "X";
    gameOver = false;
    consoleEl.innerHTML = '';
    logLine('Neues Spiel gestartet.', 'sys');
    logLine(`Du spielst ${humanMark}, KI spielt ${aiMark}.`, 'sys');
    renderBoard();
    statusEl.textContent = current === humanMark ? 'Du bist am Zug.' : 'KI denkt nach …';
    if(current === aiMark){
      setTimeout(() => { kiMove(); renderBoard(); afterMoveAiOpening(); }, 300);
    }
  }

  function afterMoveAiOpening(){
    current = nextPlayer(current);
    statusEl.textContent = 'Du bist am Zug.';
  }

  btnRestart.addEventListener('click', restart);
  btnFirst.addEventListener('click', () => {
    [humanMark, aiMark] = [aiMark, humanMark];
    restart();
  });

  renderBoard();
  logLine('Bereit. Du spielst X, KI spielt O.', 'sys');
})();
</script>

